# SerbiSure Backend - Environment Configuration Example
# Copy this file to .env and fill in the values

# Set to True for development, False for production
DEBUG=True

# Security: Generate a secret key for your project
# You can use 'python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"'
SECRET_KEY=your-secret-key-here

# Comma-separated list of hosts (e.g., 127.0.0.1,localhost,yourdomain.com)
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration
# Format: postgresql://user:password@host:port/dbname
# For local SQLite, you can leave this blank or use: sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# Security Settings (Set to True in production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
